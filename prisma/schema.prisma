generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Quoting Engine (existing) ────────────────────────────────────────────────

model Quote {
  id                String          @id @default(cuid())
  slug              String          @unique
  title             String
  address           String
  projectType       String
  status            String          @default("draft") // draft | sent | quote_signed
  scopeText         String?
  materialMarkupPct Float           @default(10)
  overheadPct       Float           @default(10)
  profitPct         Float           @default(10)
  paymentTerms      String          @default("10% due at signing. 25% due after materials purchased. Balance due net 30.")
  exclusions        String          @default("Plans. Permit fees. Any work not specifically described above. All valuables and personal property to be removed from work areas prior to work.")
  notes             String?
  quoteContacts     QuoteContact[]
  quoteCompanies    QuoteCompany[]
  // CRM link — optional until we migrate existing quotes
  projectId         String?
  project           Project?        @relation(fields: [projectId], references: [id])
  sections          LineItemSection[]
  acceptance        Acceptance?
  contract          Contract?
  signingToken      String?         @unique
  signingTokenExpiresAt DateTime?
  signedAt          DateTime?
  signedPdfPath     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  sentAt              DateTime?
  estimatedDuration   String?
  estimatedStartDate  DateTime?
  milestones        QuoteMilestone[]
  bidRequests      BidRequest[]
}

model QuoteMilestone {
  id           String  @id @default(cuid())
  quoteId      String
  quote        Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name         String
  weekNumber   Int
  duration     String?
  paymentPct   Float?
  paymentLabel String?
  position     Int

  @@unique([quoteId, position])
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  plannedDate DateTime?
  completedAt DateTime?
  position    Int
  notes       String?
  billingAmount Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  invoiceMilestones InvoiceMilestone[]
  projectTasks  ProjectTask[]
}

model LineItemSection {
  id      String     @id @default(cuid())
  title   String
  position Int
  trade    String?          // Default trade for items in this section
  quoteId String
  quote   Quote      @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  items   LineItem[]
}

model LineItem {
  id          String          @id @default(cuid())
  description String
  quantity    Float
  unit        String          @default("ea")
  unitPrice   Float           // customer-facing price per unit
  vendorCost  Float?          // internal cost per unit (null if not from catalog)
  isMaterial  Boolean         @default(false)
  position    Int
  sectionId   String
  section     LineItemSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  // CPQ link — optional, set when line item comes from component catalog
  componentId String?
  component   Component?      @relation(fields: [componentId], references: [id])
  trade       String?         // Trade classification — see src/lib/trades.ts for valid values
}

model Acceptance {
  id         String   @id @default(cuid())
  signerName String
  acceptedAt DateTime @default(now())
  ipAddress  String?
  quoteId    String   @unique
  quote      Quote    @relation(fields: [quoteId], references: [id])
  signaturePngPath  String?
}

model Contract {
  id              String    @id @default(cuid())
  quoteId         String    @unique
  quote           Quote     @relation(fields: [quoteId], references: [id])
  projectId       String?
  project         Project?  @relation(fields: [projectId], references: [id])
  status          String    @default("draft") // draft | contract_sent | executed
  htmlPath        String?   // path to assembled MSA+Exhibit A HTML
  contractAmount  Float?    // tracks total as COs are executed (set on creation from quote total)
  signingToken    String?   @unique
  signingTokenExpiresAt DateTime?
  signerName      String?
  signedAt        DateTime?
  signedPdfPath   String?
  signerIp        String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  changeOrders    ChangeOrder[]
  invoices         Invoice[]
}

model ChangeOrder {
  id              String    @id @default(cuid())
  contractId      String
  contract        Contract  @relation(fields: [contractId], references: [id])
  number          Int       // sequential per contract: 1, 2, 3...
  title           String
  scopeDelta      String    // description of scope change
  priceDelta      Float     // positive = addition, negative = credit
  status          String    @default("draft") // draft | co_sent | executed
  htmlPath        String?
  signingToken    String?   @unique
  signingTokenExpiresAt DateTime?
  signerName      String?
  signedAt        DateTime?
  signedPdfPath   String?
  signerIp        String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  invoices         Invoice[]

  @@unique([contractId, number])
}

model Invoice {
  id                    String              @id @default(cuid())
  invoiceNumber         String              @unique
  sequenceNumber        Int
  projectId             String
  project               Project             @relation(fields: [projectId], references: [id])
  contractId            String
  contract              Contract            @relation(fields: [contractId], references: [id])
  changeOrderId         String?
  changeOrder           ChangeOrder?        @relation(fields: [changeOrderId], references: [id])
  billingContactId      String
  billingContact        Contact             @relation(fields: [billingContactId], references: [id])
  billingCompanyId      String?
  billingCompany        Company?            @relation(fields: [billingCompanyId], references: [id])
  amount                Float
  amountAdjustmentNote  String?
  issueDate             DateTime            @default(now())
  dueDate               DateTime
  notes                 String?
  status                String              @default("draft") // draft | sent | viewed | paid
  htmlPath              String
  viewToken             String?             @unique
  passcode              String?
  passcodeFailures      Int                 @default(0)
  passcodeLockedUntil   DateTime?
  sentAt                DateTime?
  viewedAt              DateTime?
  paidAt                DateTime?
  paidMethod            String?             // check | ach | other
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  invoiceMilestones     InvoiceMilestone[]
}

model InvoiceMilestone {
  id          String    @id @default(cuid())
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  milestoneId String    @unique // globally unique — prevents double-billing
  milestone   Milestone @relation(fields: [milestoneId], references: [id])

  @@unique([invoiceId, milestoneId])
}

// ─── CRM ──────────────────────────────────────────────────────────────────────

// stages: opportunity_identified | quote_sent | contract_signed | closed_lost
//         preconstruction | active | punch_list | complete
model Project {
  id               String              @id @default(cuid())
  name             String
  shortCode        String?
  stage            String              @default("opportunity_identified")
  projectType      String?
  message          String?             // original inbound message from contact form
  notes            String?             // internal notes
  attachmentUrl       String?
  estimatedCloseDate  DateTime?
  contractAmount      Float?
  targetCostAmount    Float?
  estimatedStartDate  DateTime?
  estimatedEndDate    DateTime?
  timingNotes         String?
  milestones          Milestone[]
  siteAddress      String?
  siteCity         String?
  siteState        String?
  siteZip          String?
  hazardNotes      String?
  nearestER        String?
  nearestERAddress String?
  assemblyPoint    String?
  projectContacts  ProjectContact[]
  projectCompanies ProjectCompany[]
  quotes           Quote[]
  contracts        Contract[]
  teamMembers      ProjectTeamMember[]
  invoices         Invoice[]
  projectTasks         ProjectTask[]
  complianceChatMessages ComplianceChatMessage[]
  subcontractorReviews SubcontractorReview[]
  bidRequests          BidRequest[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model Contact {
  id               String           @id @default(cuid())
  firstName        String
  lastName         String?
  email            String?          @unique
  phone            String?
  type             String           @default("customer") // customer | vendor | pm | employee | other
  primaryCompany   Company?         @relation(fields: [primaryCompanyId], references: [id])
  primaryCompanyId String?
  projectContacts  ProjectContact[]
  quoteContacts    QuoteContact[]
  employee         Employee?
  invoices         Invoice[]
  contactNotes     ContactNote[]
  createdAt        DateTime         @default(now())
}

model Company {
  id               String           @id @default(cuid())
  name             String
  type             String           @default("customer") // customer | vendor | pm | subcontractor | other
  domain           String?          @unique
  phone            String?
  contacts         Contact[]
  projectCompanies ProjectCompany[]
  quoteCompanies   QuoteCompany[]
  invoices         Invoice[]
  subcontractorProfile SubcontractorProfile?
  bidInvitations       BidInvitation[]
  subcontractorReviews SubcontractorReview[]
  contactNotes         ContactNote[]
  createdAt        DateTime         @default(now())
}

// ─── Subcontractor Management ─────────────────────────────────────────────────

// 1:1 extension of Company. Only exists when company.type = "subcontractor".
model SubcontractorProfile {
  id               String   @id @default(cuid())
  companyId        String   @unique
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trades           String[] // Array of TradeId values
  licenseNumber    String?
  bidLimit         Float?
  onboardingStatus String   @default("pending") // pending | documents_requested | under_review | approved | suspended
  insuranceExpiry  DateTime?
  w9OnFile         Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  preferred Boolean  @default(false)
  flagged   Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId, companyId])
}

model SubcontractorReview {
  id              String   @id @default(cuid())
  subcontractorId String
  subcontractor   Company  @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewerId      String
  timeliness      Int      // 1-5
  communication   Int      // 1-5
  price           Int      // 1-5
  qualityOfWork   Int      // 1-5
  wouldRehire     Boolean
  notes           String?
  createdAt       DateTime @default(now())

  @@unique([subcontractorId, projectId])
}

model InHouseCapability {
  id                     String  @id @default(cuid())
  trade                  String  @unique // TradeId
  canPerform             Boolean @default(false)
  capacityCheckAvailable Boolean @default(false)
}

// ─── Bid Request Pipeline ─────────────────────────────────────────────────────

model BidRequest {
  id                  String          @id @default(cuid())
  quoteId             String
  quote               Quote           @relation(fields: [quoteId], references: [id])
  projectId           String?
  project             Project?        @relation(fields: [projectId], references: [id])
  projectType         String
  generalLocation     String
  scopeOfWork         String          // Generated scope text — no pricing, no client details
  requiredTrade       String          // TradeId
  responseDeadline    DateTime
  startWindow         String?
  specialRequirements String?
  status              String          @default("draft") // draft | sent | responses_received | awarded | cancelled
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  invitations         BidInvitation[]
}

model BidInvitation {
  id              String       @id @default(cuid())
  bidRequestId    String
  bidRequest      BidRequest   @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  subcontractorId String
  subcontractor   Company      @relation(fields: [subcontractorId], references: [id])
  sentAt          DateTime?
  status          String       @default("pending") // pending | viewed | responded | declined
  response        BidResponse?
  createdAt       DateTime     @default(now())

  @@unique([bidRequestId, subcontractorId])
}

model BidResponse {
  id               String        @id @default(cuid())
  bidInvitationId  String        @unique
  bidInvitation    BidInvitation @relation(fields: [bidInvitationId], references: [id], onDelete: Cascade)
  amount           Float
  scopeNotes       String?
  estimatedDuration String?
  availableStartDate DateTime?
  receivedAt       DateTime      @default(now())
  status           String        @default("submitted") // submitted | under_review | accepted | rejected
}

model ProjectContact {
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  role      String  @default("customer") // customer | pm | architect | gc | other

  @@id([projectId, contactId])
}

model ProjectCompany {
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String
  role      String  @default("customer") // customer | pm | architect | gc | other

  @@id([projectId, companyId])
}

model QuoteContact {
  id        String  @id @default(cuid())
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  role      String  @default("decision_maker") // decision_maker | site_contact | billing_contact

  @@unique([quoteId, contactId])
}

model QuoteCompany {
  id        String  @id @default(cuid())
  quoteId   String
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      String  @default("tenant") // tenant | landlord | property_manager | owner

  @@unique([quoteId, companyId])
}

// ─── CPQ: Component Catalog ───────────────────────────────────────────────────

model Vendor {
  id         String      @id @default(cuid())
  name       String
  website    String?
  notes      String?
  components Component[]
  createdAt  DateTime    @default(now())
}

// A specific purchasable item from a vendor with a known cost.
// When used on a quote, vendorCost is copied to LineItem.vendorCost
// and the customer-facing unitPrice is set separately (via markup or manual entry).
model Component {
  id          String     @id @default(cuid())
  name        String
  description String?
  category    String?    // e.g. "Flooring", "Electrical", "Millwork"
  vendorSku   String?
  vendorCost  Float      // what we pay the vendor per unit
  unit        String     @default("ea")
  vendor      Vendor     @relation(fields: [vendorId], references: [id])
  vendorId    String
  lineItems   LineItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  sdsUrl      String?
  isHazardous Boolean    @default(false)
}

// ─── HR: Employee Module ───────────────────────────────────────────────────────

// 1:1 extension of Contact. Only exists when contact.type = "employee".
// All required fields live here — Contact is not polluted with nullable columns.
model Employee {
  id                  String    @id @default(cuid())
  contactId           String    @unique
  contact             Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // Identity
  legalName           String
  hireDate            DateTime
  employmentType      String    // "W2" | "CONTRACTOR_1099"
  tradeClassification String    // TradeId — see src/lib/trades.ts. Legacy: superintendent/pm mapped to "other"
  activeStatus        String    @default("active") // "active" | "inactive" | "terminated"
  terminatedAt        DateTime?

  // Address
  homeAddress         String
  city                String
  state               String
  zip                 String

  // Emergency contact 1 (required)
  ec1Name             String
  ec1Relationship     String
  ec1Phone            String

  // Emergency contact 2 (optional)
  ec2Name             String?
  ec2Relationship     String?
  ec2Phone            String?

  // Optional compliance fields
  driversLicenseNumber String?
  driversLicenseExpiry DateTime?

  // Relations
  certifications      Certification[]
  onboardingSteps     OnboardingStep[]
  projectTeam         ProjectTeamMember[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// OSHA and other certifications. cardPhotoUrl required for OSHA_10 and OSHA_30.
model Certification {
  id             String    @id @default(cuid())
  employeeId     String
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type           String    // "OSHA_10" | "OSHA_30" | "FIRST_AID" | "OTHER"
  issueDate      DateTime
  expirationDate DateTime?
  cardPhotoUrl   String?
  verifiedStatus String    @default("unverified") // "unverified" | "verified"

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// Per-step tracking for digital onboarding flow.
model OnboardingStep {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  stepName    String    // "personal_info" | "emergency_contacts" | "employment_docs" |
                        // "gusto_setup" | "osha_certification" | "safety_manual_ack" |
                        // "workbook_ack" | "complete"
  completedAt DateTime?
  signerName  String?   // for acknowledgment steps
  ipAddress   String?

  @@unique([employeeId, stepName])
}

// Pre-hire invite token — allows sending onboarding link before Contact exists.
model OnboardingInvite {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  email     String
  expiresAt DateTime
  status    String    @default("pending") // "pending" | "completed" | "expired"
  contactId String?   // set after Step 1 creates the Contact record

  createdAt DateTime  @default(now())
}

// Assigns employees/contractors to a project job site.
model ProjectTeamMember {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       String   @default("worker") // "worker" | "foreman" | "superintendent"
  assignedAt DateTime @default(now())

  @@unique([projectId, employeeId])
}

// ─── Compliance & Project Planning ────────────────────────────────────────────

model ProjectTask {
  id              String           @id @default(cuid())
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  phase           String           // groups tasks: "demolition", "framing", etc.
  position        Int              // ordering within phase
  durationDays    Int
  startDay        Int              // offset from project start
  endDay          Int              // startDay + durationDays
  isMilestoneTask Boolean          @default(false)
  milestoneId     String?
  milestone       Milestone?       @relation(fields: [milestoneId], references: [id])
  isCriticalPath  Boolean          @default(false)
  status          String           @default("pending") // pending | in_progress | completed | blocked
  completedAt     DateTime?
  complianceFlags ComplianceFlag[]
  // Self-referential many-to-many for dependencies
  dependsOn       ProjectTask[]    @relation("TaskDependency")
  dependedOnBy    ProjectTask[]    @relation("TaskDependency")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ComplianceFlag {
  id            String       @id @default(cuid())
  projectTaskId String
  projectTask   ProjectTask  @relation(fields: [projectTaskId], references: [id], onDelete: Cascade)
  ruleId        String       // matches corpus file id, e.g. "osha-engineering-survey"
  severity      String       // BLOCK | WARNING | INFO
  title         String
  citation      String
  actionItem    String
  resolvedAt    DateTime?
  resolvedBy    String?
  resolvedNote  String?
  createdAt     DateTime     @default(now())
}

model ComplianceChatMessage {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  sessionId String
  role      String   // user | assistant
  content   String
  citations Json     @default("[]") // [{ruleId, citation, relevance}]
  createdAt DateTime @default(now())

  @@index([sessionId])
}
