# Pascal 0.5.x has mismatched peer deps: @pascal-app/core declares three ^0.182
# while @pascal-app/viewer declares three ^0.183. three@0.183.0 satisfies viewer
# and is minor-compatible with core. This flag reverts npm to its pre-v7 warn-
# don't-error behavior so Docker/nixpacks `npm ci` succeeds. Revisit when
# Pascal's peers align (0.5.2+).
legacy-peer-deps=true
